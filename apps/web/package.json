    "d3": "^7.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^20.12.12",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.11.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
