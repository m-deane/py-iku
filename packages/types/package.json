    "lint": "eslint src/",
    "format": "prettier --write src/ scripts/"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "prettier": "^3.3.0"
  }
}
