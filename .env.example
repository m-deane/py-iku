# py-iku local secrets — copy to .env.local and fill in real values.
# .env.local is git-ignored; this file (.env.example) is the template.
#
# After editing .env.local, scripts that need an API key can load it
# via scripts/llm_smoke_test.py (or any tool that reads .env.local).
# The API key never enters the chat transcript or git history.

# Required for convert_with_llm() and the real-LLM smoke test.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional — only needed if you use convert_with_llm(provider="openai")
OPENAI_API_KEY=
